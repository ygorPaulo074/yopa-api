# AI-ChatBot — environment template
# Copy to .env and fill in the values before starting the server.
# Run `inv setup` to generate this file interactively.

# ── Versioning ─────────────────────────────────────────────────────────────────
# Mirrors the VERSION file. Used as the Docker image tag (ai-chatbot-api:<APP_VERSION>).
APP_VERSION=0.1.0

# ── AI provider ────────────────────────────────────────────────────────────────
# Global fallback — can be left empty if every agent supplies its own key via POST /agent.
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT=30

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=AI-ChatBot
RUN_MODE=development
HOST=0.0.0.0
PORT=8000

# ── Redis (required) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
SESSION_TTL=86400

# ── Storage: local | database | webhook ───────────────────────────────────────
STORAGE_TYPE=local
DATA_PATH=./data

# Database (required when STORAGE_TYPE=database)
DATABASE_URL=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# Webhook (required when STORAGE_TYPE=webhook)
WEBHOOK_URL=

# ── Security ───────────────────────────────────────────────────────────────────
# Encrypts per-agent API keys (BYOK) and SQL connection strings (Fernet).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SQL_ENCRYPTION_KEY=

# ── Auth ───────────────────────────────────────────────────────────────────────
# standalone — Bearer {agent_id}.{secret} (default, open source)
# internal   — X-Internal-Token + X-Agent-Id injected by the Yopa Proxy
AUTH_MODE=standalone
INTERNAL_TOKEN=

# ── NLP ────────────────────────────────────────────────────────────────────────
ANALYZER_LANGUAGES=["en"]

# ── SQL tool safety ────────────────────────────────────────────────────────────
SQL_ALLOWED_DIALECTS=["postgresql","mysql","sqlite"]
SQL_QUERY_TIMEOUT=10
SQL_MAX_ROWS=50

MAX_TOOL_ROUNDS=5
LOG_LEVEL=INFO
